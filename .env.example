# .env にコピーして各キーを設定してください（詳細は README.md 3章）

# Twelve Data APIキー（FX・ゴールド・シルバー用。仮想通貨のみなら空でOK）
TWELVEDATA_API_KEY=

# Discord通知（任意）: チャンネル設定 → ウェブフックURL
DISCORD_WEBHOOK_URL=

# LINE通知（任意）: Messaging APIのチャネルアクセストークンとユーザーID
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# 株価指数・原油を有効化（Twelve Data有料プランGrow以上が必要）
ENABLE_INDICES=false

# リスク設定（省略時は右の既定値）
CAPITAL_JPY=1000000
RISK_PERCENT=1.0
DAILY_MAX_LOSS_JPY=30000
MAX_CONSEC_LOSSES=3
FALLBACK_USDJPY=150
